POSTGRES_DB=ngs_monitor
POSTGRES_USER=ngs
POSTGRES_PASSWORD=ngs

DATABASE_URL=postgresql://ngs:ngs@postgres:5432/ngs_monitor
REDIS_URL=redis://redis:6379/0

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3:8b

# Bật GPU cho container ollama (mặc định để trống/comment = CPU-only, không đổi hành vi).
# Chỉ set 1 trong 2 dòng COMPOSE_FILE dưới tùy loại GPU của máy, rồi chạy `docker compose up -d`
# như cũ — Compose tự đọc COMPOSE_FILE từ .env để merge thêm file override GPU tương ứng.
# COMPOSE_PATH_SEPARATOR=; ép dùng dấu ";" để tách danh sách file trên MỌI hệ điều hành —
# bắt buộc phải có dòng này vì mặc định Compose dùng ":" trên Linux/macOS nhưng ":" lại
# đụng ký tự ổ đĩa trên Windows (VD D:\...), nếu thiếu dòng này COMPOSE_FILE sẽ lỗi trên
# Windows. Luôn để dòng dưới bật cùng lúc với 1 trong 2 dòng COMPOSE_FILE.
# COMPOSE_PATH_SEPARATOR=;
# NVIDIA: cần cài nvidia-container-toolkit trên host trước.
# COMPOSE_FILE=docker-compose.yml;docker-compose.gpu-nvidia.yml
# AMD (ROCm): không dùng được qua Docker Desktop/WSL2 (thiếu /dev/kfd trong VM WSL2, đã
# verify lỗi thật 2026-07-14) — chỉ cài được nếu Docker chạy trên Linux thật, không phải
# Windows.
# COMPOSE_FILE=docker-compose.yml;docker-compose.gpu-amd.yml

AI_CONFIDENCE_THRESHOLD=0.6
AI_MAX_CONTENT_LENGTH=5000
AI_TIMEOUT_SECONDS=360
# Số bài AI xử lý đồng thời trong 1 job. Mặc định 1 = tuần tự, an toàn cho CPU-only
# (laptop). Chỉ tăng khi chạy trên hạ tầng có GPU — tăng trên CPU-only có thể LÀM CHẬM
# hơn (tranh chấp CPU giữa các request), không tự nhiên nhanh hơn. Benchmark lại trước
# khi đổi trên môi trường mới.
AI_CONCURRENCY=1

CRAWLER_DELAY_SECONDS=1.5
CRAWLER_MAX_RETRIES=3
CRAWLER_TIMEOUT_SECONDS=30

STORAGE_PATH=./storage
DOCX_TEMPLATE_PATH=./templates/report_template.docx

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

MAX_ARTICLES_PER_JOB=
# true = chia đều MAX_ARTICLES_PER_JOB cho từng nguồn đã chọn (dư dồn nguồn đầu theo thứ
# tự source_ids), false/để trống = giữ hành vi cũ (nguồn đầu tiên ăn hết ngân sách trước)
EVEN_DISTRIBUTE_ACROSS_SOURCES=false
